# 复制为 ".env" 后填写。不要提交真实密钥。
# 已在 shell 中设置的环境变量优先级更高（不会被本文件覆盖）。

# 真实模型调用所需（OpenAI 兼容接口）
MIKU_OPENAI_API_KEY=sk-your-key-here

# OpenRouter 示例：
# MIKU_OPENAI_BASE_URL=https://openrouter.ai/api/v1
# MIKU_MODEL=tencent/hy3:free

# 官方 OpenAI 默认（未设置时）：
# MIKU_OPENAI_BASE_URL=https://api.openai.com/v1
# MIKU_MODEL=gpt-4o-mini

MIKU_OPENAI_BASE_URL=https://openrouter.ai/api/v1
MIKU_MODEL=gpt-4o-mini

# 可选：强制 MockProvider（AgentAction 的 JSON 数组）
# MIKU_MOCK_RESPONSES=[{"type":"final_answer","summary":"done"}]
